# =============================================================================
# WeatherFlow v1 — copy to .env and fill in.
# Loaded from project root and backend/.env.
# =============================================================================

# ----- LLM (OpenAI-compatible) -----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
CHAT_MODEL=gpt-4o-mini
CHAT_TEMPERATURE=0.4

# ----- Networking -----
# Comma-separated API hosts that must BYPASS the system HTTP(S) proxy.
# Set this if a local proxy (Clash/V2Ray...) MITMs your LLM/embedding domains
# and calls fail intermittently with CERTIFICATE_VERIFY_FAILED.
# e.g. NO_PROXY_HOSTS=api.minimaxi.com,api.siliconflow.cn
NO_PROXY_HOSTS=

# ----- App -----
# Runtime data is intentionally outside the source tree.
DATA_DIR=${HOME}/.local/share/weatherflow/data
DB_FILENAME=weatherflow.db
APP_HOST=127.0.0.1
APP_PORT=8765
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ----- Single user (v1) -----
DEFAULT_USER_ID=default
# 'local' uses system tz; or e.g. Asia/Shanghai
TIMEZONE=local

# ----- Scheduler (T2 = every 6h fixed slots; DMW heartbeat) -----
SCHEDULER_ENABLED=true
# Local hours when scheduled_check fires (§8.1)
SCHEDULED_CHECK_HOURS=0,6,12,18
# Safety-net heartbeat for DelayedMemoryWriter (§9.2)
MEMORY_WRITER_INTERVAL_HOURS=12

# ----- MCP servers (Calendar + GitHub) -----
WF_GITHUB_MCP_COMMAND=uv run python -m mcp_servers.weatherflow_github.server
WF_CALENDAR_MCP_COMMAND=uv run python -m mcp_servers.weatherflow_calendar.server
WF_MCP_TOOL_TIMEOUT_SECONDS=20

# ----- GitHub -----
GITHUB_TOKEN=
# Comma-separated owner/repo list to pull into github_snapshot
MONITORED_GITHUB_REPOS=wesleyzhangwq/weatherflow

# ----- Google Calendar -----
# Preferred: run `uv run wf setup-calendar --credentials ./credentials.json`
# and set this to the token file path it prints.
GOOGLE_CALENDAR_TOKEN_FILE=
# Short-lived fallback for debugging only.
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_CALENDAR_ID=primary
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3

# ----- Profile.md (L3) -----
# Defaults to ${DATA_DIR}/memory if empty.
MEMORY_MARKDOWN_DIR=

# ----- ContextLoader -----
BUNDLE_TOKEN_BUDGET=8000

# ----- ReAct loop -----
RHYTHM_AGENT_MAX_TURNS=8

# ----- DelayedMemoryWriter thresholds (§9.2) -----
DMW_SECTION_COOLDOWN_HOURS=24
DMW_PATTERN_WINDOW_DAYS=14
DMW_PATTERN_MIN_COUNT=3
DMW_MIN_CONFIDENCE=0.6

# ----- Proposal expiry (§7.4 + ADR D9) -----
PROPOSAL_EXPIRY_HOURS=24

# ----- Frontend -----
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765

# ----- CLI -----
WF_API_BASE=http://127.0.0.1:8765
WF_DASHBOARD_URL=http://127.0.0.1:3000

# ----- Docker Compose -----
WF_DATA_DIR=${HOME}/.local/share/weatherflow/data

# =============================================================================
# WeatherFlow v2 additions
# =============================================================================

# ----- Semantic memory (L2.5 / mem0 + Qdrant) -----
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=weatherflow_memories
# L3-fast profile layer (ADR-006): separate collection, written with infer=True.
QDRANT_PROFILE_COLLECTION=weatherflow_profile
PROFILE_CONSOLIDATION_ENABLED=true
MEM0_API_KEY=
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
# Vector dimension of the embedding model. Must match the model output and the
# Qdrant collection. Ali text-embedding-v3/v4 = 1024, OpenAI ada-002 = 1536.
EMBEDDING_DIMS=1024
SEMANTIC_RECALL_LIMIT=5

# ----- LangGraph -----
GRAPH_CHECKPOINTS_DB=graph_checkpoints.db

# ----- Observability (Langfuse + OpenTelemetry) -----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://127.0.0.1:3001
OTEL_EXPORTER=console

# ----- Desktop proactivity -----
PROACTIVITY_ENABLED=true

# --- Langfuse self-host secrets (docker-compose) ---
# Generate fresh values; NEVER commit real ones:
#   openssl rand -base64 32   -> LANGFUSE_SALT
#   openssl rand -hex 32      -> LANGFUSE_ENCRYPTION_KEY
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=
LANGFUSE_NEXTAUTH_SECRET=langfuse-secret-change-me
