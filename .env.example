# =============================================================================
# WeatherFlow — copy to .env and fill in. Loaded from project root (and backend/.env).
# =============================================================================

# ----- LLM (OpenAI-compatible) -----
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-replace-me
CHAT_MODEL=gpt-4o-mini

# ----- Per-task model overrides (optional; empty = CHAT_MODEL) -----
CHAT_MODEL_STATE=
CHAT_MODEL_REFLECTION=
CHAT_MODEL_PLANNING=
CHAT_MODEL_MEMORY=

# ----- Anthropic (reserved; unused by default) -----
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# ----- App -----
# Runtime data is intentionally outside the source tree.
DATA_DIR=${HOME}/.local/share/weatherflow/data
DB_FILENAME=weatherflow.db
APP_HOST=127.0.0.1
APP_PORT=8765
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# ----- Scheduler -----
SCHEDULER_ENABLED=true
EVENING_REFLECTION_CRON=22:00
WEEKLY_REVIEW_CRON=sun:21:00
SCHEDULER_TIMEZONE=local

# ----- Dev Review providers -----
# Provider mode: direct (default), mcp, or dual (compare both; return direct result)
DEV_REVIEW_PROVIDER_MODE=direct
# MCP server launch commands (used when DEV_REVIEW_PROVIDER_MODE=mcp or dual)
WF_GITHUB_MCP_COMMAND=uv run python -m mcp_servers.weatherflow_github.server
WF_CALENDAR_MCP_COMMAND=uv run python -m mcp_servers.weatherflow_calendar.server
WF_MCP_TOOL_TIMEOUT_SECONDS=20
# Set to true only after confirming write operations in dry-run mode first
WF_MCP_WRITE_TOOLS_ENABLED=false
GITHUB_TOKEN=
# Preferred: run `uv run wf setup-calendar --credentials ./credentials.json`
# and set this to the token path printed by the command.
GOOGLE_CALENDAR_TOKEN_FILE=
# Temporary fallback for debugging short-lived Calendar API access.
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_CALENDAR_ID=primary
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3

# ----- Frontend -----
NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765

# ----- Memory -----
# Readable profile Markdown; default is DATA_DIR/memory if empty.
MEMORY_MARKDOWN_DIR=

# ----- CLI -----
WF_API_BASE=http://127.0.0.1:8765
# Browser URL for ``wf dashboard``; also used by ``wf stop`` to find the Next dev port.
WF_DASHBOARD_URL=http://127.0.0.1:3000
# If the CLI is used outside the repo clone, set absolute path to WeatherFlow root.
# WF_PROJECT_ROOT=

# ----- Docker Compose -----
# Host path mounted into the backend container at /app/data.
WF_DATA_DIR=${HOME}/.local/share/weatherflow/data
