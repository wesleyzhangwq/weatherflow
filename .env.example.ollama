# Local-first profile: WeatherFlow runs entirely offline through Ollama.
#
# Setup:
#   brew install ollama
#   ollama serve &
#   ollama pull qwen2.5:7b
#
# Then:
#   cp .env.example.ollama .env
#   uvicorn app.main:app --reload --port 8765

# ===== LLM (Ollama exposes an OpenAI-compatible API) =====
OPENAI_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_API_KEY=ollama          # not validated, but cannot be empty
CHAT_MODEL=qwen2.5:7b
# Use a smaller model for structured tasks (state JSON / profile refresh)
# and a stronger one for the prose-like ones, all locally.
CHAT_MODEL_STATE=qwen2.5:7b
CHAT_MODEL_REFLECTION=qwen2.5:7b
CHAT_MODEL_PLANNING=qwen2.5:7b
CHAT_MODEL_MEMORY=qwen2.5:7b

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

DATA_DIR=${HOME}/.local/share/weatherflow/data
DB_FILENAME=weatherflow.db
APP_HOST=127.0.0.1
APP_PORT=8765
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

SCHEDULER_ENABLED=true
EVENING_REFLECTION_CRON=22:00
WEEKLY_REVIEW_CRON=sun:21:00
SCHEDULER_TIMEZONE=local

GITHUB_TOKEN=
GOOGLE_CALENDAR_TOKEN_FILE=
GOOGLE_CALENDAR_ACCESS_TOKEN=
GOOGLE_CALENDAR_CALENDAR_ID=primary
GOOGLE_CALENDAR_BASE_URL=https://www.googleapis.com/calendar/v3

NEXT_PUBLIC_API_BASE=http://127.0.0.1:8765
WF_API_BASE=http://127.0.0.1:8765
WF_DATA_DIR=${HOME}/.local/share/weatherflow/data
