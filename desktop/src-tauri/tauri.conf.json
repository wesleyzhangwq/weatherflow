{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeatherFlow",
  "version": "3.0.0-alpha.1",
  "identifier": "ai.weatherflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "companion",
        "title": "WeatherFlow Companion",
        "url": "index.html?surface=companion",
        "width": 190,
        "height": 190,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "shadow": false
      }
    ],
    "security": { "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'" }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "externalBin": ["binaries/weatherflow-core"],
    "macOS": { "minimumSystemVersion": "13.0" }
  }
}
