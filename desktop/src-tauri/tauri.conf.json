{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WeatherFlow",
  "version": "3.0.0-alpha.1",
  "identifier": "ai.weatherflow.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": { "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; style-src 'self' 'unsafe-inline'" }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "shortDescription": "A rhythm-aware general agent harness that stays local and supervised.",
    "copyright": "Copyright © 2026 WeatherFlow. All rights reserved.",
    "externalBin": ["binaries/weatherflow-core"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
